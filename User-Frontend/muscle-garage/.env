# API Configuration
# ==================
# For APK/Production: Use the hosted Vercel backend
# EXPO_PUBLIC_API_URL=https://muscle-garage-3rgl.vercel.app/api

# For Local Testing: Point to localhost
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# If testing from a physical device on Wi-Fi, use your computer's IP instead of localhost
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.X:5000/api (find IP with 'ipconfig' on Windows)
